# ERP Accounting System — Environment Configuration
# انسخ هذا الملف إلى .env وعدّل القيم

# ============================================
# Application
# ============================================
APP_NAME=نظام ERP محاسبي متكامل
APP_VERSION=5.0.0
DEBUG=False

# ============================================
# Database
# ============================================
DATABASE_URL=sqlite:///./erp_accounting.db
DB_ECHO=False

# ============================================
# Security
# ============================================
SECRET_KEY=change-me-in-production
BCRYPT_COST=12
SESSION_DURATION_HOURS=8
MAX_LOGIN_ATTEMPTS=5
LOCK_DURATION_MINUTES=15

# ============================================
# AI / LLM (أضف مفتاحك هنا)
# ============================================
# OpenAI:
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_MODEL=gpt-4o-mini

# Local LLM (Ollama):
# LOCAL_LLM_MODEL=llama3:8b
# OLLAMA_HOST=http://localhost:11434

# ============================================
# OCR (Tesseract)
# ============================================
# OCR_LANGUAGE=ara+eng

# ============================================
# Backup
# ============================================
BACKUP_DIR=./backups
# BACKUP_ENCRYPTION_KEY=your-encryption-key

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO

# ============================================
# Company Info (يظهر في الفواتير والتقارير)
# ============================================
COMPANY_NAME=شركتي
COMPANY_NAME_EN=My Company
COMPANY_TAX_NUMBER=
COMPANY_PHONE=
COMPANY_EMAIL=
COMPANY_ADDRESS=

# ============================================
# Defaults
# ============================================
DEFAULT_CURRENCY=SAR
DEFAULT_TAX_RATE=15.0
FISCAL_YEAR_START_MONTH=1
FISCAL_YEAR_START_DAY=1
